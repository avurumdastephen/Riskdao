;; Risk Categories & Specialized Underwriter Certification System\n;; Enables categorized risk assessment and specialized underwriter certification\n\n(define-constant CONTRACT_OWNER tx-sender)\n(define-constant ERR_UNAUTHORIZED (err u300))\n(define-constant ERR_INVALID_CATEGORY (err u301))\n(define-constant ERR_NOT_CERTIFIED (err u302))\n(define-constant ERR_ALREADY_CERTIFIED (err u303))\n(define-constant ERR_INSUFFICIENT_EXPERIENCE (err u304))\n(define-constant ERR_CERTIFICATION_EXPIRED (err u305))\n(define-constant ERR_INVALID_EXAM_SCORE (err u306))\n(define-constant ERR_EXAM_NOT_AVAILABLE (err u307))\n\n;; Risk category definitions\n(define-constant CATEGORY_AUTO u1)\n(define-constant CATEGORY_HEALTH u2)\n(define-constant CATEGORY_PROPERTY u3)\n(define-constant CATEGORY_LIFE u4)\n(define-constant CATEGORY_BUSINESS u5)\n(define-constant CATEGORY_CYBER u6)\n\n;; Certification levels\n(define-constant CERT_LEVEL_BASIC u1)\n(define-constant CERT_LEVEL_ADVANCED u2)\n(define-constant CERT_LEVEL_EXPERT u3)\n\n;; System parameters\n(define-data-var certification-validity-period uint u52560) ;; ~1 year in blocks\n(define-data-var min-exam-score uint u75)\n(define-data-var experience-threshold uint u10)\n(define-data-var next-exam-id uint u1)\n\n;; Risk category information\n(define-map risk-categories\n  { category-id: uint }\n  {\n    name: (string-ascii 30),\n    description: (string-ascii 100),\n    active: bool,\n    min-certification-level: uint,\n    total-certified-underwriters: uint\n  }\n)\n\n;; Underwriter certifications\n(define-map underwriter-certifications\n  { underwriter: principal, category-id: uint }\n  {\n    certification-level: uint,\n    earned-at: uint,\n    expires-at: uint,\n    exam-score: uint,\n    total-assessments: uint,\n    accuracy-rate: uint,\n    active: bool\n  }\n)\n\n;; Certification exams\n(define-map certification-exams\n  { exam-id: uint }\n  {\n    category-id: uint,\n    certification-level: uint,\n    questions-count: uint,\n    passing-score: uint,\n    exam-fee: uint,\n    available: bool,\n    created-by: principal\n  }\n)\n\n;; Exam attempts\n(define-map exam-attempts\n  { exam-id: uint, underwriter: principal }\n  {\n    score: uint,\n    attempted-at: uint,\n    passed: bool,\n    attempt-number: uint\n  }\n)\n\n;; Category-specific policy classifications\n(define-map policy-classifications\n  { policy-id: uint }\n  {\n    category-id: uint,\n    risk-subcategory: uint,\n    requires-expert-review: bool,\n    certified-votes-only: bool,\n    classification-confidence: uint\n  }\n)\n\n;; Read-only function to get risk category info\n(define-read-only (get-risk-category (category-id uint))\n  (map-get? risk-categories { category-id: category-id })\n)\n\n;; Read-only function to get underwriter certification\n(define-read-only (get-underwriter-certification (underwriter principal) (category-id uint))\n  (map-get? underwriter-certifications { underwriter: underwriter, category-id: category-id })\n)\n\n;; Read-only function to check if underwriter is certified for category\n(define-read-only (is-certified-for-category (underwriter principal) (category-id uint))\n  (match (map-get? underwriter-certifications { underwriter: underwriter, category-id: category-id })\n    cert (and (get active cert) (< stacks-block-height (get expires-at cert)))\n    false\n  )\n)\n\n;; Read-only function to get policy classification\n(define-read-only (get-policy-classification (policy-id uint))\n  (map-get? policy-classifications { policy-id: policy-id })\n)\n\n;; Initialize default risk categories\n(define-public (initialize-risk-categories)\n  (begin\n    (asserts! (is-eq tx-sender CONTRACT_OWNER) ERR_UNAUTHORIZED)\n    \n    ;; Auto insurance\n    (map-set risk-categories\n      { category-id: CATEGORY_AUTO }\n      {\n        name: "Auto Insurance",\n        description: "Motor vehicle and transportation coverage",\n        active: true,\n        min-certification-level: CERT_LEVEL_BASIC,\n        total-certified-underwriters: u0\n      }\n    )\n    \n    ;; Health insurance\n    (map-set risk-categories\n      { category-id: CATEGORY_HEALTH }\n      {\n        name: "Health Insurance",\n        description: "Medical and healthcare coverage",\n        active: true,\n        min-certification-level: CERT_LEVEL_ADVANCED,\n        total-certified-underwriters: u0\n      }\n    )\n    \n    ;; Property insurance\n    (map-set risk-categories\n      { category-id: CATEGORY_PROPERTY }\n      {\n        name: "Property Insurance",\n        description: "Real estate and personal property coverage",\n        active: true,\n        min-certification-level: CERT_LEVEL_BASIC,\n        total-certified-underwriters: u0\n      }\n    )\n    \n    ;; Life insurance\n    (map-set risk-categories\n      { category-id: CATEGORY_LIFE }\n      {\n        name: "Life Insurance",\n        description: "Life and disability coverage",\n        active: true,\n        min-certification-level: CERT_LEVEL_ADVANCED,\n        total-certified-underwriters: u0\n      }\n    )\n    \n    (ok true)\n  )\n)\n\n;; Function to classify a policy into risk category\n(define-public (classify-policy (policy-id uint) (category-id uint) (risk-subcategory uint))\n  (let (\n    (category (unwrap! (map-get? risk-categories { category-id: category-id }) ERR_INVALID_CATEGORY))\n    (policy-data (unwrap! (contract-call? .Riskdao get-policy policy-id) ERR_INVALID_CATEGORY))\n  )\n    ;; Only policy applicant or contract owner can classify\n    (asserts! (or (is-eq tx-sender (get applicant policy-data)) \n                  (is-eq tx-sender CONTRACT_OWNER)) ERR_UNAUTHORIZED)\n    (asserts! (get active category) ERR_INVALID_CATEGORY)\n    \n    (map-set policy-classifications\n      { policy-id: policy-id }\n      {\n        category-id: category-id,\n        risk-subcategory: risk-subcategory,\n        requires-expert-review: (>= (get min-certification-level category) CERT_LEVEL_EXPERT),\n        certified-votes-only: true,\n        classification-confidence: u85\n      }\n    )\n    (ok true)\n  )\n)\n\n;; Function to take certification exam\n(define-public (take-certification-exam (category-id uint) (certification-level uint))\n  (let (\n    (category (unwrap! (map-get? risk-categories { category-id: category-id }) ERR_INVALID_CATEGORY))\n    (underwriter-data (unwrap! (contract-call? .Riskdao get-underwriter tx-sender) ERR_UNAUTHORIZED))\n    (existing-cert (map-get? underwriter-certifications { underwriter: tx-sender, category-id: category-id }))\n    ;; Mock exam score calculation (in real implementation would be based on actual answers)\n    (exam-score (+ u70 (mod stacks-block-height u25))) ;; Random score between 70-94\n    (passed (>= exam-score (var-get min-exam-score)))\n  )\n    (asserts! (get active category) ERR_INVALID_CATEGORY)\n    (asserts! (<= certification-level CERT_LEVEL_EXPERT) ERR_INVALID_CATEGORY)\n    (asserts! (>= certification-level CERT_LEVEL_BASIC) ERR_INVALID_CATEGORY)\n    \n    ;; Check experience requirement for advanced levels\n    (asserts! (or (<= certification-level CERT_LEVEL_BASIC)\n                  (>= (get total-votes underwriter-data) (var-get experience-threshold))) \n              ERR_INSUFFICIENT_EXPERIENCE)\n    \n    (if passed\n      (let (\n        (expiry-block (+ stacks-block-height (var-get certification-validity-period)))\n        (new-cert-count (if (is-none existing-cert) u1 u0))\n      )\n        (map-set underwriter-certifications\n          { underwriter: tx-sender, category-id: category-id }\n          {\n            certification-level: certification-level,\n            earned-at: stacks-block-height,\n            expires-at: expiry-block,\n            exam-score: exam-score,\n            total-assessments: u0,\n            accuracy-rate: u0,\n            active: true\n          }\n        )\n        \n        ;; Update category stats\n        (map-set risk-categories\n          { category-id: category-id }\n          (merge category {\n            total-certified-underwriters: (+ (get total-certified-underwriters category) new-cert-count)\n          })\n        )\n        (ok exam-score)\n      )\n      (err ERR_INVALID_EXAM_SCORE)\n    )\n  )\n)\n\n;; Function to renew certification\n(define-public (renew-certification (category-id uint))\n  (let (\n    (certification (unwrap! (map-get? underwriter-certifications { underwriter: tx-sender, category-id: category-id }) \n                             ERR_NOT_CERTIFIED))\n    (category (unwrap! (map-get? risk-categories { category-id: category-id }) ERR_INVALID_CATEGORY))\n  )\n    (asserts! (get active category) ERR_INVALID_CATEGORY)\n    (asserts! (get active certification) ERR_CERTIFICATION_EXPIRED)\n    \n    ;; Check if certification is close to expiry (within 30 days)\n    (asserts! (< (- (get expires-at certification) stacks-block-height) u4320) ERR_CERTIFICATION_EXPIRED)\n    \n    ;; Renewal requirements: minimum accuracy and assessment count\n    (asserts! (>= (get accuracy-rate certification) u60) ERR_INSUFFICIENT_EXPERIENCE)\n    (asserts! (>= (get total-assessments certification) u5) ERR_INSUFFICIENT_EXPERIENCE)\n    \n    (map-set underwriter-certifications\n      { underwriter: tx-sender, category-id: category-id }\n      (merge certification {\n        expires-at: (+ stacks-block-height (var-get certification-validity-period)),\n        earned-at: stacks-block-height\n      })\n    )\n    (ok true)\n  )\n)\n\n;; Function to validate underwriter eligibility for category-specific voting\n(define-public (validate-category-vote-eligibility (underwriter principal) (policy-id uint))\n  (let (\n    (classification (unwrap! (map-get? policy-classifications { policy-id: policy-id }) ERR_INVALID_CATEGORY))\n    (category-id (get category-id classification))\n    (certification (map-get? underwriter-certifications { underwriter: underwriter, category-id: category-id }))\n  )\n    (if (get certified-votes-only classification)\n      (match certification\n        cert (and (get active cert) \n                  (< stacks-block-height (get expires-at cert))\n                  (>= (get certification-level cert) \n                      (get min-certification-level (unwrap! (map-get? risk-categories { category-id: category-id }) \n                                                             ERR_INVALID_CATEGORY))))\n        false\n      )\n      true ;; If certification not required, always allow\n    )\n  )\n)\n\n;; Function to update certification performance after voting\n(define-public (update-certification-performance (underwriter principal) (policy-id uint) (vote-accurate bool))\n  (let (\n    (classification (map-get? policy-classifications { policy-id: policy-id }))\n  )\n    (match classification\n      class-data\n      (let (\n        (category-id (get category-id class-data))\n        (certification (map-get? underwriter-certifications { underwriter: underwriter, category-id: category-id }))\n      )\n        (match certification\n          cert-data\n          (let (\n            (new-assessments (+ (get total-assessments cert-data) u1))\n            (accurate-votes (if vote-accurate \n                              (+ (get accuracy-rate cert-data) u1) \n                              (get accuracy-rate cert-data)))\n            (new-accuracy-rate (if (> new-assessments u0)\n                                 (/ (* accurate-votes u100) new-assessments)\n                                 u0))\n          )\n            (map-set underwriter-certifications\n              { underwriter: underwriter, category-id: category-id }\n              (merge cert-data {\n                total-assessments: new-assessments,\n                accuracy-rate: new-accuracy-rate\n              })\n            )\n            (ok true)\n          )\n          (ok true) ;; No certification to update\n        )\n      )\n      (ok true) ;; No classification found\n    )\n  )\n)\n\n;; Function to get certified underwriters for a category\n(define-read-only (get-category-certified-count (category-id uint))\n  (match (map-get? risk-categories { category-id: category-id })\n    category (get total-certified-underwriters category)\n    u0\n  )\n)\n\n;; Function to check certification requirements for policy type\n(define-read-only (get-certification-requirements (policy-id uint))\n  (match (map-get? policy-classifications { policy-id: policy-id })\n    classification\n    (let (\n      (category (map-get? risk-categories { category-id: (get category-id classification) }))\n    )\n      (match category\n        cat-data\n        (some {\n          category-name: (get name cat-data),\n          min-certification-level: (get min-certification-level cat-data),\n          certified-votes-only: (get certified-votes-only classification),\n          requires-expert-review: (get requires-expert-review classification)\n        })\n        none\n      )\n    )\n    none\n  )\n)\n\n;; Admin function to update category settings\n(define-public (update-category-settings (category-id uint) (min-cert-level uint) (active bool))\n  (let (\n    (category (unwrap! (map-get? risk-categories { category-id: category-id }) ERR_INVALID_CATEGORY))\n  )\n    (asserts! (is-eq tx-sender CONTRACT_OWNER) ERR_UNAUTHORIZED)\n    (asserts! (and (>= min-cert-level CERT_LEVEL_BASIC) \n                   (<= min-cert-level CERT_LEVEL_EXPERT)) ERR_INVALID_CATEGORY)\n    \n    (map-set risk-categories\n      { category-id: category-id }\n      (merge category {\n        min-certification-level: min-cert-level,\n        active: active\n      })\n    )\n    (ok true)\n  )\n)\n\n;; Read-only function to get underwriter's certification status summary\n(define-read-only (get-underwriter-certification-summary (underwriter principal))\n  (let (\n    (auto-cert (map-get? underwriter-certifications { underwriter: underwriter, category-id: CATEGORY_AUTO }))\n    (health-cert (map-get? underwriter-certifications { underwriter: underwriter, category-id: CATEGORY_HEALTH }))\n    (property-cert (map-get? underwriter-certifications { underwriter: underwriter, category-id: CATEGORY_PROPERTY }))\n    (life-cert (map-get? underwriter-certifications { underwriter: underwriter, category-id: CATEGORY_LIFE }))\n  )\n    {\n      auto-certified: (is-some auto-cert),\n      health-certified: (is-some health-cert),\n      property-certified: (is-some property-cert),\n      life-certified: (is-some life-cert),\n      total-categories: (+ (if (is-some auto-cert) u1 u0)\n                          (+ (if (is-some health-cert) u1 u0)\n                            (+ (if (is-some property-cert) u1 u0)\n                               (if (is-some life-cert) u1 u0))))\n    }\n  )\n)\n\n;; Initialize the system with default categories\n(try! (initialize-risk-categories))\n